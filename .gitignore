# OS / editor
.DS_Store
**/.DS_Store
.idea/
# VS Code currently only contains machine-local ESP-IDF extension state.
.vscode/

# Local assistant / workspace state
.claude/
.omc/
**/.omc/
.pre-commit-cache/

# Embedded build outputs
build/
**/build/
build-*/
**/build-*/
managed_components/
**/managed_components/
# Keep only the checked-in baseline config; local generated sdkconfig files stay ignored.
sdkconfig
sdkconfig.old
sdkconfig.*
!sdkconfig.defaults
**/sdkconfig.old

# Rust outputs
target/
**/target/

# Logs and temp files
*.log
*.tmp
*.swp
*.swo

# Local vendor / experiments not tracked in this repo
/esp-idf/
/esp-idf-*/
